# Copy to .env and adjust.

PUMP_BACKEND=mock          # mock | real  (real = drive the IBT-2 H-bridge on the Pi)
TICK_HZ=20                 # simulation + telemetry rate (Hz)

# --- real pump: IBT-2 (BTS7960), hardware PWM, used only when PUMP_BACKEND=real ---
# GPIO12/13 are the Pi's hardware-PWM pins (RP1). The driver's VCC MUST be 3.3 V,
# NOT 5 V (see CLAUDE.md). One-time Pi setup:
#   dtoverlay=pwm-2chan,pin=12,func=4,pin2=13,func2=4   in /boot/firmware/config.txt
#   sudo pip3 install rpi-hardware-pwm --break-system-packages   ; then reboot
PUMP_RPWM_PIN=12
PUMP_LPWM_PIN=13
PUMP_REN_PIN=23
PUMP_LEN_PIN=24
PUMP_IN_IS_RPWM=false      # our pump: IN=LPWM/GPIO13, OUT=RPWM/GPIO12 (set true to swap)
PUMP_PWM_HZ=20000
PUMP_PWM_CHIP=auto         # auto | 0 | 2   (trixie / kernel 6.12 = 0)
PUMP_RATE_ML_S=2.0         # full-speed (100% duty) flow, ml/s — set during calibration

# Game/PK tuning (bands, clearance, dosing, scoring) lives in app/game/.
