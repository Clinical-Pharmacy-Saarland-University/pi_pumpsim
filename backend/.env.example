# Copy to .env and adjust. These are the startup defaults; calibration can also
# be changed live from the admin panel (press "A" in the UI).

PUMP_BACKEND=mock          # mock | real   (real = drive GPIO via gpiozero on the Pi)

# --- calibration ---
PUMP_RATE_ML_S=2.0         # delivered flow at full speed (calibrate on real hardware)
DEAD_VOLUME_ML=5.0         # tubing volume to prime before water reaches the avatar
CAPACITY_ML=100.0          # avatar vessel capacity
TARGET_LOW_ML=40.0         # therapeutic window, lower bound
TARGET_HIGH_ML=60.0        # therapeutic window, upper bound
CLEARANCE_K=0.01           # first-order elimination rate (1/s); 0 disables the "drain"
TICK_HZ=20                 # simulation + telemetry rate (Hz)

# --- real pump GPIO (BCM numbering), used only when PUMP_BACKEND=real ---
PUMP_GPIO_PIN=18
