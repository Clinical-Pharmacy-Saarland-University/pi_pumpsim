# pumpsim kiosk — sway compositor config (landscape on the 720x1280 Touch Display 2).
# install.sh substitutes __APP_DIR__ and installs this to /etc/pumpsim/sway-kiosk.config.
#
# Why sway (not cage): cage can't rotate its output. The Touch Display 2's native KMS
# mode is 720x1280 (portrait); sway rotates the Wayland output — and the touch input
# follows the transform automatically — so no kernel-level rotation is needed.

# Rotate the (single) touch display to landscape. If the picture is upside-down, 90 -> 270.
output * transform 90

# kiosk look: no borders, fullscreen everything, no idle blanking (we don't run swayidle).
default_border none
default_floating_border none
for_window [app_id=".*"] fullscreen enable
for_window [title=".*"] fullscreen enable

# launch Chromium (which loads the local backend UI)
exec __APP_DIR__/deploy/kiosk.sh
