# Template — deploy/install.sh substitutes __USER__ and installs this (mode 0440)
# to /etc/sudoers.d/pumpsim-power, after validating it with `visudo -cf`.
#
# Lets the pumpsim backend (User=__USER__) cleanly power off / reboot the kiosk from
# the on-screen admin "System" panel — and NOTHING else. The backend binds to
# 127.0.0.1 only, so these endpoints are not reachable from the network.
__USER__ ALL=(root) NOPASSWD: /usr/bin/systemctl poweroff, /usr/bin/systemctl reboot
